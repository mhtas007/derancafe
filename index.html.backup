            { cat: 'food', sub: 'calzone', img: images.calzone, price: 8000, name: { ku: 'کالزۆنای گەورە', en: 'Large Calzone' }, desc: { ku: 'هەموو جۆرەکان (گۆشت، مریشک، مەشەکەل، خەزرەوات)', en: 'All types (Meat, Chicken, Mixed, Vegetable)' } },
            { cat: 'food', sub: 'calzone', img: images.calzone, price: 12000, name: { ku: 'کالزۆنای خێزانی', en: 'Family Calzone' }, desc: { ku: 'هەموو جۆرەکان (گۆشت، مریشک، مەشەکەل، خەزرەوات)', en: 'All types (Meat, Chicken, Mixed, Vegetable)' } },

            // Sides (خواردنە لاوەکییەکان)
            { cat: 'food', sub: 'sides', img: images.fries, price: 3500, name: { ku: 'فینگەر', en: 'Fries' }, desc: { ku: '', en: '' } },
            { cat: 'food', sub: 'sides', img: images.appetizers, price: 3500, name: { ku: 'موقەبیلات', en: 'Appetizers' }, desc: { ku: '', en: '' } },
          ];

          const filteredItems = menuItems.filter(item => {
            if (searchQuery.trim()) {
              const q = searchQuery.toLowerCase();
              return (
                item.name.ku.toLowerCase().includes(q) ||
                item.name.en.toLowerCase().includes(q)
              );
            }
            if (item.cat !== activeCategory) return false;
            if (activeSubCategory !== 'all' && item.sub && item.sub !== activeSubCategory) return false;
            return true;
          });

          const handleCategoryChange = (catId) => {
            setActiveCategory(catId);
            setActiveSubCategory('all');
            setSearchQuery(''); 
          };

          const handleLanguageSelect = (selectedLang) => {
            setLang(selectedLang);
            setView('menu');
          };

          const bgClass = "bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-red-950 via-neutral-950 to-green-950 text-neutral-100"; 
          
          // --- Language Data ---
          const languages = [
            { 
                code: 'ku', 
                label: 'کوردی', 
                sub: 'Kurdish', 
                flag: 'https://upload.wikimedia.org/wikipedia/commons/thumb/3/35/Flag_of_Kurdistan.svg/1280px-Flag_of_Kurdistan.svg.png' 
            },
            { 
                code: 'en', 
                label: 'English', 
                sub: 'English', 
                flag: 'https://upload.wikimedia.org/wikipedia/en/thumb/a/ae/Flag_of_the_United_Kingdom.svg/800px-Flag_of_the_United_Kingdom.svg.png' 
            }
          ];

          const activeFlag = languages.find(l => l.code === lang)?.flag;

          const ContactButton = ({ icon: Icon, label, onClick }) => (
            <button 
              onClick={onClick} 
              className="flex flex-col items-center justify-center gap-2 group w-full py-4 rounded-xl bg-black/40 border border-white/5 hover:border-amber-500/40 hover:bg-amber-900/10 transition-all duration-300 backdrop-blur-sm"
            >
              <Icon size={20} strokeWidth={1.5} className="text-neutral-400 group-hover:text-amber-500 transition-colors duration-300" />
              <span className="text-[9px] font-medium tracking-widest uppercase text-neutral-500 group-hover:text-amber-400 transition-colors">{label}</span>
            </button>
          );

          // Powered By Component
          const PoweredBy = () => (
            <div className="fixed bottom-0 left-0 right-0 bg-neutral-950 border-t border-white/5 py-2 z-40 flex justify-center items-center shadow-[0_-10px_20px_rgba(0,0,0,0.5)]">
                <p className={`text-[10px] text-neutral-500 uppercase font-sans flex items-center justify-center gap-1 ${lang === 'en' ? 'tracking-[0.2em]' : ''}`}>
                    <span>{uiText.poweredBy[lang]}</span>
                    <a href="https://masmenu.masmenu.workers.dev/" target="_blank" rel="noopener noreferrer" className="text-amber-500 font-bold tracking-widest hover:text-amber-400 transition-colors">Mas Menu</a>
                </p>
            </div>
          );

          if (view === 'welcome') {
            return (
              <div className={`min-h-screen ${bgClass} flex flex-col items-center justify-between p-8 pb-16 ${fontClass} relative overflow-hidden`}>
                <div className="absolute inset-0 z-0 bg-black">
                     <video 
                      autoPlay 
                      loop 
                      muted 
                      playsInline 
                      className="bg-video absolute inset-0 w-full h-full object-cover z-0"
                      onError={(e) => { 
                        e.target.style.display = 'none'; 
                        document.body.classList.add('bg-video-fallback');
                      }}
                    >
                      <source src="assets/video/background.mp4" type="video/mp4" />
                    </video>
                    {/* Minimal overlay for text readability while keeping video clear */}
                    <div className="absolute inset-0 bg-black/10 z-0"></div>
                </div>
                
                <div className={`flex-1 flex flex-col justify-center w-full max-w-md z-10 transition-all duration-1000 transform ${isLoaded ? 'translate-y-0 opacity-100' : 'translate-y-10 opacity-0'}`}>
                  
                  <div className="text-center mb-12 relative">
                      <div className="w-48 h-48 mx-auto rounded-full flex items-center justify-center relative z-10 mb-8 animate-in fade-in zoom-in duration-1000 overflow-hidden shadow-[0_0_40px_rgba(245,158,11,0.3)] border-2 border-amber-500/20 bg-black/50 backdrop-blur-sm">
                        <img 
                            src="https://scared-moccasin-vmjwkvdcjg.edgeone.app/cafe-logo.png" 
                            alt="Dêran Logo" 
                            className="w-full h-full object-cover"
                            onError={(e) => {
                                e.target.onerror = null; 
                                e.target.src = getPlaceholder('Dêran');
                            }}
                        />
                      </div>
                      <h1 className="text-4xl font-bold text-white mb-2 font-serif tracking-widest drop-shadow-lg">DÊRAN</h1>
                      <p className="text-amber-500 text-sm tracking-[0.3em] uppercase drop-shadow-md">Cafe & Hookah Lounge</p>
                  </div>

                  <div className="grid gap-4">
                      {languages.map((l, i) => (
                        <button 
                          key={l.code}
                          onClick={() => handleLanguageSelect(l.code)}
                          style={{ transitionDelay: `${i * 150}ms` }}
                          className="group relative overflow-hidden w-full h-20 rounded-xl border border-white/10 hover:border-amber-500/50 bg-neutral-900/60 hover:bg-neutral-900/90 backdrop-blur-md transition-all duration-300 flex items-center justify-between px-6 shadow-lg hover:shadow-amber-900/20 active:scale-[0.98]"
                        >
                          <div className="absolute inset-0 bg-gradient-to-r from-amber-500/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
                          
                          <div className="flex items-center gap-4 z-10">
                            <div className="w-10 h-10 rounded-full overflow-hidden border border-white/20 shadow-md group-hover:border-amber-500/50 transition-colors">
                                <img src={l.flag} alt={l.label} className="w-full h-full object-cover" />
                            </div>
                            <div className="flex flex-col items-start">
                                <span className="text-xl font-bold text-white group-hover:text-amber-400 transition-colors duration-300 tracking-wide font-serif">{l.label}</span>
                                <span className="text-[10px] text-neutral-400 uppercase tracking-widest group-hover:text-amber-500/80 transition-colors">{l.sub}</span>
                            </div>
                          </div>
                          
                          <div className="w-8 h-8 rounded-full border border-white/10 flex items-center justify-center text-neutral-500 group-hover:border-amber-500 group-hover:text-amber-500 transition-all duration-300 bg-white/5">
                            <ChevronRight size={16} strokeWidth={2} />
                          </div>
                        </button>
                      ))}
                  </div>
                </div>

                <div className={`w-full max-w-md mt-12 grid grid-cols-3 gap-3 z-10 transition-all duration-1000 delay-500 transform ${isLoaded ? 'translate-y-0 opacity-100' : 'translate-y-10 opacity-0'}`}>
                  <ContactButton icon={Phone} label={uiText.call[lang]} onClick={() => window.open(`tel:${contactInfo.phone}`)} />
                  <ContactButton icon={Instagram} label="Instagram" onClick={() => window.open(contactInfo.instagramUrl)} />
                  <ContactButton icon={MapPin} label={uiText.location[lang]} onClick={() => window.open(contactInfo.locationUrl)} />
                </div>
                <PoweredBy />
              </div>
            );
          }

          return (
            <div dir={dir} className={`min-h-screen ${bgClass} ${fontClass} relative`}>
              <header className={`sticky top-0 z-40 bg-neutral-950/80 backdrop-blur-2xl border-b border-white/5 shadow-2xl transition-all duration-500 ${isLoaded ? 'translate-y-0 opacity-100' : '-translate-y-full opacity-0'}`}>
                <div className="max-w-md mx-auto px-4 pt-4 pb-2">
                  <div className="flex items-center justify-between mb-6">
                    <div className="flex items-center gap-4">
                      <button onClick={() => setShowInfoModal(true)} className="w-11 h-11 rounded-full bg-neutral-900 border border-white/10 flex items-center justify-center text-amber-500 active:scale-95 transition-all hover:border-amber-500/50 hover:bg-neutral-800 hover:shadow-[0_0_15px_rgba(245,158,11,0.2)]">
                          <Info size={20} />
                      </button>
                      <div>
                        <h2 className="font-bold text-2xl leading-none text-white tracking-wide font-serif">DÊRAN</h2>
                        <span className="text-[9px] text-amber-500 uppercase tracking-[0.2em] font-medium">Cafe</span>
                      </div>
                    </div>
                    
                    <div className="flex items-center gap-3">
                      <button onClick={() => setShowLangModal(true)} className="h-11 pl-2 pr-4 rounded-full bg-neutral-900 border border-white/10 flex items-center gap-2 text-neutral-400 hover:text-white hover:border-amber-500/30 transition-all active:scale-95 group">
                        <div className="w-6 h-6 rounded-full overflow-hidden border border-white/20 relative">
                            <img src={activeFlag} alt={lang} className="w-full h-full object-cover" />
                        </div>
                        <span className="text-xs font-bold uppercase tracking-wider group-hover:text-amber-400 transition-colors">{lang}</span>
                      </button>
                      <button onClick={() => setView('welcome')} className="w-11 h-11 rounded-full bg-neutral-900 border border-white/10 flex items-center justify-center text-neutral-400 hover:text-white hover:bg-neutral-800 transition-colors active:scale-95">
                        <ArrowLeft size={20} className={dir === 'rtl' ? 'rotate-180' : ''} />
                      </button>
                    </div>
                  </div>

                  <div className="flex overflow-x-auto gap-4 pb-2 no-scrollbar scroll-smooth pl-1">
                    {categories.map((cat, i) => (
                      <button
                        key={cat.id}
                        onClick={() => handleCategoryChange(cat.id)}
                        className={`flex-shrink-0 flex flex-col items-center gap-2 group transition-all duration-500`}
                        style={{ transitionDelay: `${i * 50}ms` }}
                      >
                        <div className={`w-16 h-16 rounded-[1.2rem] overflow-hidden relative transition-all duration-300 ${activeCategory === cat.id && !searchQuery ? 'ring-2 ring-amber-500/80 shadow-[0_0_20px_rgba(245,158,11,0.4)] scale-105' : 'grayscale opacity-60 scale-95 hover:opacity-100 hover:scale-100'}`}>
                            <img 
                                src={cat.img} 
                                alt={cat.label.en} 
                                className="w-full h-full object-cover bg-neutral-800"
                                onError={(e) => {
                                    e.target.onerror = null; 
                                    e.target.src = getPlaceholder(cat.label.en);
                                }}
                            />
                        </div>
                        <span className={`text-[10px] font-bold uppercase tracking-wider transition-colors duration-300 ${activeCategory === cat.id && !searchQuery ? 'text-amber-500' : 'text-neutral-500'}`}>
                          {cat.label[lang]}
                        </span>
                      </button>
                    ))}
                  </div>
                </div>

                {subCategories[activeCategory] && !searchQuery && (
                  <div className="bg-neutral-950/80 border-t border-white/5 backdrop-blur-md">
                      <div className="flex overflow-x-auto gap-2 px-4 py-3 no-scrollbar max-w-md mx-auto">
                        {subCategories[activeCategory].map((sub) => (
                          <button
                            key={sub.id}
                            onClick={() => setActiveSubCategory(sub.id)}
                            className={`px-5 py-2 rounded-full text-xs font-bold whitespace-nowrap transition-all border ${
                              activeSubCategory === sub.id
                                ? 'bg-amber-500 text-black border-amber-500 shadow-[0_0_15px_rgba(245,158,11,0.3)]'
                                : 'bg-neutral-900 border-neutral-800 text-neutral-500 hover:text-neutral-300 hover:border-neutral-700'
                            }`}
                          >
                            {sub.label[lang]}
                          </button>
                        ))}
                      </div>
                  </div>
                )}
              </header>

              <main className="max-w-md mx-auto px-4 py-6 pb-32">
                <div className="mb-8 relative z-0">
                  <div className="absolute -inset-0.5 bg-gradient-to-r from-amber-500/20 to-amber-600/20 rounded-2xl blur opacity-30 group-focus-within:opacity-100 transition duration-500"></div>
                  <div className="relative group">
                    <input
                      type="text"
                      value={searchQuery}
                      onChange={(e) => setSearchQuery(e.target.value)}
                      placeholder={uiText.search[lang]}
                      className={`w-full bg-[#111] border border-white/10 rounded-xl py-4 ${dir === 'rtl' ? 'pr-12 pl-12' : 'pl-12 pr-12'} text-white placeholder:text-neutral-600 focus:outline-none focus:border-amber-500/50 transition-all shadow-inner`}
                    />
                    <div className={`absolute top-1/2 -translate-y-1/2 ${dir === 'rtl' ? 'right-4' : 'left-4'}`}>
                      <Search className="text-neutral-500 group-focus-within:text-amber-500 transition-colors" size={20} />
                    </div>
                    {searchQuery && (
                      <button onClick={() => setSearchQuery('')} className={`absolute top-1/2 -translate-y-1/2 ${dir === 'rtl' ? 'left-3' : 'right-3'} p-1.5 hover:bg-white/10 rounded-full transition-colors text-neutral-500 hover:text-white`}>
                        <X size={16} />
                      </button>
                    )}
                  </div>
                </div>

                <div className="flex items-end justify-between px-1 mb-6 border-b border-white/5 pb-2">
                  <h3 className="text-2xl font-bold text-white flex items-center gap-2">
                    {!searchQuery && <div className="w-1 h-6 bg-amber-500 rounded-full shadow-[0_0_10px_rgba(245,158,11,0.5)]"></div>}
                    {searchQuery 
                      ? uiText.searchResults[lang]
                      : categories.find(c => c.id === activeCategory)?.label[lang]
                    }
                  </h3>
                  <span className="text-[10px] text-amber-500/60 font-mono bg-amber-500/5 px-2 py-1 rounded-md border border-amber-500/10">
                    {filteredItems.length} Items
                  </span>
                </div>

                <div className="grid grid-cols-2 gap-4">
                  {filteredItems.length > 0 ? (
                    filteredItems.map((item, index) => (
                      <div 
                        key={index} 
                        className={`group relative bg-neutral-900 border border-white/5 rounded-[1.5rem] overflow-hidden shadow-lg transition-all duration-500 hover:shadow-[0_10px_30px_rgba(0,0,0,0.5)] hover:border-amber-500/30 hover:-translate-y-1`}
                      >
                        <div className="relative aspect-[4/5] overflow-hidden bg-neutral-800">
                            <img 
                                src={item.img} 
                                alt={item.name.en} 
                                className="w-full h-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-110" 
                                onError={(e) => {
                                    e.target.onerror = null; 
                                    e.target.src = getPlaceholder(item.name.en);
                                }}
                            />
                            <div className="absolute inset-0 bg-gradient-to-t from-black/90 via-black/40 to-transparent opacity-90"></div>
                            <div className="absolute top-3 right-3 z-10">
                               <div className="bg-neutral-950/80 backdrop-blur-md border border-amber-500/40 px-3 py-1.5 rounded-xl flex items-baseline gap-1 shadow-lg shadow-black/50">
                                  <span className="text-amber-400 font-bold text-sm tracking-wide drop-shadow-md">{item.price.toLocaleString()}</span>
                                  <span className="text-[9px] text-amber-500/70 font-medium tracking-wider">{uiText.currency[lang]}</span>
                               </div>
                            </div>
                            <div className="absolute bottom-0 left-0 right-0 p-4">
                                <h4 className="font-bold text-lg text-white leading-tight mb-2 drop-shadow-md tracking-tight">{item.name[lang]}</h4>
                                {item.desc[lang] && (
                                    <p className="text-[11px] text-neutral-300/90 line-clamp-2 leading-relaxed font-light">{item.desc[lang]}</p>
                                )}
                            </div>
                        </div>
                      </div>
                    ))
                  ) : (
                    <div className="col-span-2 py-24 flex flex-col items-center justify-center text-neutral-600 gap-4">
                      <div className="w-16 h-16 rounded-full bg-neutral-900 flex items-center justify-center border border-white/5">
                        <Search className="w-6 h-6 opacity-30" />
                      </div>
                      <p className="text-sm font-light tracking-wide">{searchQuery ? uiText.noResults[lang] : 'No items found'}</p>
                    </div>
                  )}
                </div>
              </main>

              <PoweredBy />

              {showInfoModal && (
                <div className="fixed inset-0 z-50 flex items-center justify-center px-4 animate-in fade-in duration-300">
                  <div className="absolute inset-0 bg-black/90 backdrop-blur-md" onClick={() => setShowInfoModal(false)}></div>
                  <div className="bg-[#111] border border-white/10 w-full max-w-sm rounded-[2rem] p-8 relative z-10 shadow-2xl">
                    <button onClick={() => setShowInfoModal(false)} className="absolute top-6 right-6 text-neutral-500 hover:text-white transition-colors">
                      <X size={24} />
                    </button>
                    <div className="text-center space-y-8">
                      <div className="w-20 h-20 bg-amber-500/10 rounded-full flex items-center justify-center mx-auto text-amber-500 border border-amber-500/20 shadow-[0_0_30px_rgba(245,158,11,0.1)]">
                        <Info size={36} />
                      </div>
                      <div className="space-y-2">
                        <h3 className="text-2xl font-bold text-white">{uiText.welcome[lang]}</h3>
                        <p className="text-neutral-500 text-sm tracking-wide">Open Daily: 10:00 AM - 2:00 AM</p>
                      </div>
                      <div className="space-y-4">
                        {[
                          { icon: Phone, label: uiText.call[lang], val: contactInfo.phone, link: `tel:${contactInfo.phone}` },
                          { icon: MapPin, label: uiText.location[lang], val: contactInfo.location, link: contactInfo.locationUrl },
                          { icon: Instagram, label: uiText.follow[lang], val: contactInfo.instagram, link: contactInfo.instagramUrl },
                        ].map((item, i) => (
                          <a key={i} href={item.link} target="_blank" rel="noreferrer" className="flex items-center gap-5 p-4 rounded-2xl bg-neutral-900 border border-white/5 hover:bg-neutral-800 hover:border-amber-500/20 transition-all group">
                            <div className="w-10 h-10 rounded-full bg-neutral-800 flex items-center justify-center text-amber-500 group-hover:bg-amber-500 group-hover:text-black transition-colors">
                              <item.icon size={18} />
                            </div>
                            <div className="flex-1 text-left">
                              <div className="text-[10px] uppercase tracking-widest text-neutral-500 group-hover:text-amber-500/70 transition-colors">{item.label}</div>
                              <div className="text-sm font-bold text-white mt-0.5">{item.val}</div>
                            </div>
                            <ExternalLink size={14} className="text-neutral-700 group-hover:text-amber-500 transition-colors" />
                          </a>
                        ))}
                      </div>
                    </div>
                  </div>
                </div>
              )}

              {showLangModal && (
                <div className="fixed inset-0 z-50 flex items-end sm:items-center justify-center sm:px-4 animate-in fade-in duration-300">
                    <div className="absolute inset-0 bg-black/90 backdrop-blur-md" onClick={() => setShowLangModal(false)}></div>
                    <div className="bg-[#111] border-t sm:border border-white/10 w-full max-w-sm rounded-t-[2.5rem] sm:rounded-[2.5rem] p-8 relative z-10 shadow-2xl animate-in slide-in-from-bottom duration-300">
                        <div className="w-12 h-1 bg-neutral-800 rounded-full mx-auto mb-8 sm:hidden"></div>
                        <div className="text-center mb-8">
                            <h3 className="text-2xl font-bold text-white tracking-tight">{uiText.selectLang[lang]}</h3>
                        </div>
                        <div className="space-y-3">
                            {languages.map((l) => (
                                <button
                                    key={l.code}
                                    onClick={() => {
                                        handleLanguageSelect(l.code);
                                        setShowLangModal(false);
                                    }}
                                    className={`w-full p-4 rounded-2xl flex items-center justify-between border transition-all duration-300 group ${
                                        lang === l.code 
                                        ? 'bg-amber-500 text-black border-amber-500 shadow-[0_0_20px_rgba(245,158,11,0.3)]' 
                                        : 'bg-neutral-900 border-white/5 text-neutral-400 hover:bg-neutral-800 hover:border-white/10'
                                    }`}
                                >
                                    <div className="flex items-center gap-4">
                                        <div className={`w-10 h-10 rounded-full overflow-hidden border ${lang === l.code ? 'border-black/20' : 'border-white/10'}`}>
                                            <img src={l.flag} alt={l.label} className="w-full h-full object-cover" />
                                        </div>
                                        <div className="flex flex-col items-start">
                                            <span className="font-bold text-lg">{l.label}</span>
                                            <span className={`text-[10px] uppercase tracking-wider ${lang === l.code ? 'text-black/60' : 'text-neutral-600'}`}>{l.sub}</span>
                                        </div>
                                    </div>
                                    {lang === l.code && <div className="bg-black/20 p-1 rounded-full"><Check size={16} /></div>}
                                </button>
                            ))}
                        </div>
                        <button onClick={() => setShowLangModal(false)} className="mt-8 w-full py-4 rounded-2xl bg-neutral-900 border border-white/5 text-neutral-400 text-sm font-bold tracking-widest uppercase hover:bg-neutral-800 hover:text-white transition-colors">
                            {uiText.close[lang]}
                        </button>
                    </div>
                </div>
              )}
            </div>
          );
        };

        const root = createRoot(document.getElementById('root'));
        root.render(<DeranMenu />);
    </script>
</body>
</html>